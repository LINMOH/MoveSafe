{
  "name": "movesafe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:env": "node scripts/build-env.js",
    "preview": "vite preview",
    "electron:dev": "bun run build:env && bun run build && bun x electron .",
    "electron:pack": "bun run build:env && bun run build && electron-builder",
    "electron:pack:win": "bun run build:env && bun run build && electron-builder --win --x64 --publish never",
    "electron:pack:mac": "bun run build:env && bun run build && electron-builder --mac --x64 --publish never",
    "electron:pack:linux": "bun run build:env && bun run build && electron-builder --linux --x64 --publish never",
    "electron:pack:all": "bun run build:env && bun run build && electron-builder --win --mac --linux --x64 --publish never",
    "package:full": "bun run build:env && bun run build && electron-builder --win --x64 --publish never",
    "package:portable": "bun run build:env && bun run build && electron-builder --win --x64 --publish never -c.win.target=portable"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "dotenv": "^17.3.1",
    "echarts": "^6.0.0",
    "express": "^5.2.1",
    "jose": "^6.1.3",
    "node-fetch": "^3.3.2",
    "vue": "^3.5.29",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "has-flag": "^5.0.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "@electron/packager": "^19.0.5",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.movesafe.app",
    "productName": "MoveSafe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "package.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "resources",
        "filter": [
          ".env",
          ".env.*",
          "ed25519_private.pem",
          "ed25519_public.pem"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "MoveSafe-${version}-win-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "MoveSafe-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "artifactName": "MoveSafe-${version}-linux-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "MoveSafe-${version}-win-${arch}-portable.exe"
    }
  }
}
