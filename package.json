{
  "name": "movesafe",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "bun server/scraper.js",
    "electron:dev": "bun run build && bun x electron .",
    "electron:pack": "bun run build && electron-builder --win --publish never",
    "electron:packager:win": "bun run build && bun x electron-packager . MoveSafe --platform=win32 --arch=x64 --out=release --overwrite --prune=false",
    "package:full": "bun run build && electron-builder --win --x64 --publish never",
    "package:portable": "bun run build && electron-builder --win --x64 --publish never -c.win.target=portable"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.0",
    "echarts": "^5.5.0",
    "express": "^4.21.0",
    "jose": "^6.1.3",
    "node-fetch": "2",
    "vue": "^3.5.25",
    "vue-echarts": "^6.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.2",
    "electron": "^40.6.0",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.movesafe.app",
    "productName": "MoveSafe",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "electron/**",
      "server/**",
      "package.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "resources",
        "filter": [
          ".env",
          ".env.*",
          "ed25519_private.pem",
          "ed25519_public.pem"
        ]
      }
    ],
    "win": {
      "sign": false,
      "signDlls": false,
      "verifyUpdateCodeSignature": false,
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": ["sha256"],
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        },
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "artifactName": "MoveSafe-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "MoveSafe-${version}-win-${arch}-portable.exe"
    }
  }
}
